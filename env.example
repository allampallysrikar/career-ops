# career-ops — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env

# ── Gemini Integration (Issue #344) ─────────────────────────────────────────
# Required for: node gemini-eval.mjs "JD text here"
# Free API key: https://aistudio.google.com/apikey
# Free tier: 15 RPM / 1M tokens/day with gemini-2.5-flash (no billing needed)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional: Override default Gemini model ───────────────────────────────────
# Default: gemini-2.5-flash (free-tier, fast)
# Alternatives: gemini-1.5-flash, gemini-1.5-pro, gemini-2.5-flash-thinking-exp
# GEMINI_MODEL=gemini-2.5-flash

# ── Other integrations ───────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_key_here   # For Claude-based workflows
# OPENAI_API_KEY=your_openai_key_here          # Future OpenAI integration

# ─────────────────────────────────────────────────────────────────────────────
# EXTENDED INTEGRATIONS (career-ops-extended)
# ─────────────────────────────────────────────────────────────────────────────

# ── Job Discovery: Adzuna API ─────────────────────────────────────────────────
# Broad job search across 20+ countries — free, no card needed
# Get keys: https://developer.adzuna.com/signup
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_API_KEY=your_adzuna_api_key_here

# ── Job Discovery: JSearch via RapidAPI ──────────────────────────────────────
# Aggregates LinkedIn + Indeed + Glassdoor jobs — 200 req/month free
# Get key: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=your_rapidapi_key_here

# ── Contact Finder: Snov.io ──────────────────────────────────────────────────
# Find hiring manager emails — 50 credits/month free, no card needed
# Get keys: https://app.snov.io/api-setting
SNOV_CLIENT_ID=your_snov_client_id_here
SNOV_CLIENT_SECRET=your_snov_client_secret_here

# ── Email Sending: Gmail OAuth2 ──────────────────────────────────────────────
# Send cold emails + parse inbox replies — completely free
# Setup: https://console.cloud.google.com/ → APIs → Gmail API → OAuth2 credentials
# Scopes needed: gmail.send, gmail.readonly, gmail.modify
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REDIRECT_URI=http://localhost:3000/oauth/gmail/callback
GMAIL_REFRESH_TOKEN=  # Auto-populated after first login via: node send-email.mjs --auth

# ── Email Sending: Microsoft Outlook (optional alternative to Gmail) ──────────
# Setup: https://portal.azure.com/ → App registrations
OUTLOOK_CLIENT_ID=your_outlook_client_id_here
OUTLOOK_CLIENT_SECRET=your_outlook_client_secret_here
OUTLOOK_REFRESH_TOKEN=  # Auto-populated after first login

# ── Web Dashboard ────────────────────────────────────────────────────────────
DASHBOARD_PORT=3000

# ── Job Alert Scheduler ──────────────────────────────────────────────────────
SCHEDULER_CRON=0 */4 * * *   # Every 4 hours (default)
SCHEDULER_MIN_SCORE=4.0       # Only alert on jobs scoring >= 4.0/5
ALERT_EMAIL=your_email@example.com

# ─────────────────────────────────────────────────────────────────────────────
# PHASE 9 EXTENSIONS (ATS Check, Referral Finder, Company Intel)
# ─────────────────────────────────────────────────────────────────────────────

# ── ATS Score Checker ─────────────────────────────────────────────────────────
# No additional API keys needed — uses GEMINI_API_KEY above.
# ATS_MIN_SCORE=60           # Warn if tailored CV scores below this (0-100)

# ── Referral Finder ───────────────────────────────────────────────────────────
# No API keys needed — uses your exported LinkedIn Connections CSV.
# LINKEDIN_CONNECTIONS_CSV=~/Downloads/Connections.csv   # Optional: set default path

# ── Company Intel Monitor ─────────────────────────────────────────────────────
# No additional API keys needed — uses GEMINI_API_KEY above.
# INTEL_CACHE_TTL_HOURS=48   # How long to cache company intel (default: 48h)
# INTEL_AVOID_BLOCK=true     # Scheduler: block emails to 🔴 AVOID companies (default: true)
